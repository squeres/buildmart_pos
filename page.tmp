feather.replace();

// ── Global data ───────────────────────────────────────────────────
const PRODUCTS  = [{"id":6,"name":"Knauf RotBand 30 кг.","sku":"AUTO-CFFCD24C","unit":"мешок","base_unit":"pallet","base_cost_price":200000,"base_sale_price":210000,"price":200000,"units":[{"code":"pallet","label":"Палета","ratio":1,"purchase_price":83.33,"sale_price":140000,"price":83.33},{"code":"мешок","label":"Мешок","ratio":50,"purchase_price":2500,"sale_price":3500,"price":2500},{"code":"на_вес","label":"На вес","ratio":1500,"purchase_price":125000,"sale_price":200,"price":125000}]},{"id":5,"name":"Лампочка 100W","sku":"L100WXS","unit":"pcs","base_unit":"pcs","base_cost_price":300,"base_sale_price":600,"price":300,"units":[{"code":"pcs","label":"шт","ratio":1,"purchase_price":300,"sale_price":600,"price":300}]},{"id":7,"name":"Ротгипс 25 кг.","sku":"AUTO-B9DFB635","unit":"мешок","base_unit":"bag","base_cost_price":2500,"base_sale_price":3000,"price":2500,"units":[{"code":"bag","label":"Палета","ratio":1,"purchase_price":130000,"sale_price":150000,"price":130000},{"code":"мешок","label":"Мешок","ratio":50,"purchase_price":50,"sale_price":3000,"price":50},{"code":"на_вес","label":"На вес","ratio":1250,"purchase_price":2,"sale_price":150,"price":2}]},{"id":9,"name":"Семей Цемент 20 кг","sku":"AUTO-A15B8EE8","unit":"мешок","base_unit":"bag","base_cost_price":120000,"base_sale_price":3000,"price":120000,"units":[{"code":"bag","label":"Палета","ratio":1,"purchase_price":120000,"sale_price":120000,"price":120000},{"code":"мешок","label":"Мешок","ratio":50,"purchase_price":96,"sale_price":2500,"price":96},{"code":"на_вес","label":"На вес","ratio":1250,"purchase_price":2400,"sale_price":100,"price":2400}]},{"id":8,"name":"Экопол 25 кг","sku":"AUTO-0A71EC7B","unit":"мешок","base_unit":"bag","base_cost_price":150000,"base_sale_price":175000,"price":150000,"units":[{"code":"bag","label":"Палета","ratio":1,"purchase_price":150000,"sale_price":170000,"price":150000},{"code":"мешок","label":"Мешок","ratio":40,"purchase_price":3750,"sale_price":4500,"price":3750},{"code":"на_вес","label":"На вес","ratio":1000,"purchase_price":150,"sale_price":250,"price":150}]}];
const PROD_MAP  = {};
PRODUCTS.forEach(p => PROD_MAP[p.id] = p);

const AJAX_URL   = "https:\/\/buildmart.local\/modules\/receipts\/ajax_create.php";
const CSRF_TOKEN = document.querySelector('input[name="_token"]').value;

let rowIndex  = -1;
let _targetRow = null; // row that triggered the product modal
let prodUnitIndex = 0;
const prodUnitRowsWrap = document.getElementById('prod-unit-rows');
const prodUnitPriceRowsWrap = document.getElementById('prod-unit-price-rows');
const prodBaseUnitSelect = document.getElementById('prod-unit');
const prodBaseUnitLabel = document.getElementById('prod-unit-label');
const prodUnitPriceState = {};

function getProductUnit(product, unitCode) {
  return (product?.units || []).find(unit => unit.code === unitCode) || product?.units?.[0] || null;
}

function fillUnitOptions(select, product, selectedCode = '') {
  if (!select) return;
  const units = product?.units || [];
  select.innerHTML = units.map(unit => `<option value="${unit.code}" ${unit.code === selectedCode ? 'selected' : ''}>${unit.label}</option>`).join('');
  if (!selectedCode && units[0]) select.value = units[0].code;
}

function rememberRowPrice(tr, product, unitCode, price) {
  const overrides = JSON.parse(tr.dataset.priceOverrides || '{}');
  overrides[unitCode] = parseFloat(price || 0);
  tr.dataset.priceOverrides = JSON.stringify(overrides);
}

function applyRowUnitPrice(tr, product, unitCode) {
  const unit = getProductUnit(product, unitCode);
  if (!unit) return;
  const priceInput = tr.querySelector('.row-price');
  const overrides = JSON.parse(tr.dataset.priceOverrides || '{}');
  const nextPrice = overrides[unitCode] ?? unit.purchase_price ?? unit.price ?? 0;
  priceInput.value = Number(nextPrice).toFixed(2);
}

function renderReceiptUnitMatrix(tr, product) {
  const container = tr.querySelector('.row-unit-matrix');
  const unitSelect = tr.querySelector('.row-unit');
  const selectedLabel = tr.querySelector('.row-selected-unit');
  const priceJsonInput = tr.querySelector('.row-unit-prices-json');
  const saleJsonInput = tr.querySelector('.row-sale-prices-json');
  if (!container || !unitSelect || !product) return;

  const existing = {
    ...JSON.parse(priceJsonInput?.value || '{}'),
    ...JSON.parse(tr.dataset.priceOverrides || '{}'),
  };
  const saleState = {
    ...JSON.parse(saleJsonInput?.value || '{}'),
  };
  const state = {};
  (product.units || []).forEach((unit) => {
    state[unit.code] = parseFloat(existing[unit.code] ?? unit.purchase_price ?? unit.price ?? 0) || 0;
    saleState[unit.code] = parseFloat(saleState[unit.code] ?? unit.sale_price ?? 0) || 0;
  });
  tr.dataset.priceOverrides = JSON.stringify(state);
  if (priceJsonInput) priceJsonInput.value = JSON.stringify(state);
  if (saleJsonInput) saleJsonInput.value = JSON.stringify(saleState);

  container.innerHTML = (product.units || []).map((unit) => `
    <div style="display:grid;grid-template-columns:auto minmax(130px,1.2fr) minmax(120px,1fr);gap:8px;align-items:end;padding:8px 10px;border:1px solid var(--border-soft);border-radius:10px;background:var(--bg-raised)">
      <label style="display:flex;align-items:center;justify-content:center;height:36px">
        <input type="radio" class="row-doc-unit" name="row_doc_unit_${tr.rowIndex}" value="${unit.code}" ${unit.code === unitSelect.value ? 'checked' : ''}>
      </label>
      <div class="form-group mb-0">
        <label class="form-label">Ед. изм.</label>
        <input type="text" class="form-control" value="${unit.label}" readonly>
      </div>
      <div class="form-group mb-0">
        <label class="form-label">Цена</label>
        <input type="number" class="form-control form-control-sm row-unit-card-price" data-unit="${unit.code}" value="${Number(state[unit.code] || 0).toFixed(2)}" min="0" step="0.01">
      </div>
    </div>
  `).join('');

  container.querySelectorAll('.row-doc-unit').forEach((radio) => {
    radio.addEventListener('change', () => {
      unitSelect.value = radio.value;
      if (selectedLabel) selectedLabel.textContent = unitSelect.selectedOptions[0]?.textContent || '';
      applyRowUnitPrice(tr, product, radio.value);
      recalcRow(tr);
    });
  });
  container.querySelectorAll('.row-unit-card-price').forEach((input) => {
    input.addEventListener('input', () => {
      const overrides = JSON.parse(tr.dataset.priceOverrides || '{}');
      overrides[input.dataset.unit] = parseFloat(input.value || 0) || 0;
      tr.dataset.priceOverrides = JSON.stringify(overrides);
      if (priceJsonInput) priceJsonInput.value = JSON.stringify(overrides);
      if (unitSelect.value === input.dataset.unit) {
        tr.querySelector('.row-price').value = Number(overrides[input.dataset.unit]).toFixed(2);
      }
      recalcRow(tr);
    });
  });
  if (selectedLabel) selectedLabel.textContent = unitSelect.selectedOptions[0]?.textContent || '';
}

function modalBasePrice(code) {
  return parseFloat(prodUnitPriceState[0]?.[code] || 0) || 0;
}

function modalCurrentUnits() {
  const units = [{
    label: (prodBaseUnitLabel?.value || prodBaseUnitSelect?.selectedOptions?.[0]?.text || 'Base').trim() || 'Base',
    ratio: 1,
    code: 'base',
  }];
  let cumulative = 1;
  document.querySelectorAll('#prod-unit-rows .prod-unit-row').forEach((row, idx) => {
    const label = (row.querySelector('.prod-unit-label')?.value || '').trim() || `Unit ${idx + 1}`;
    const stepValue = parseFloat(row.querySelector('.prod-unit-step')?.value || 1) || 1;
    cumulative *= stepValue > 0 ? stepValue : 1;
    units.push({
      label,
      ratio: cumulative,
      code: label.toLowerCase().replace(/\s+/g, '_'),
    });
  });
  return units;
}

function renderModalUnitPrices() {
  if (!prodUnitPriceRowsWrap) return;
  const units = modalCurrentUnits();
  prodUnitPriceRowsWrap.innerHTML = units.map((unit, idx) => {
    const purchase = prodUnitPriceState[idx]?.purchase ?? (idx === 0 ? '0.00' : (modalBasePrice('purchase') / Math.max(1, unit.ratio)).toFixed(2));
    const retail = prodUnitPriceState[idx]?.retail ?? (idx === 0 ? '0.00' : (modalBasePrice('retail') / Math.max(1, unit.ratio)).toFixed(2));
    return `
      <div style="display:grid;grid-template-columns:minmax(150px,1.1fr) repeat(2,minmax(120px,1fr));gap:10px;align-items:end">
        <div class="form-group mb-0">
          <label class="form-label">${idx === 0 ? 'База' : 'Единица'}</label>
          <input type="text" class="form-control" value="${unit.label}" readonly>
        </div>
        <div class="form-group mb-0">
          <label class="form-label">Закупка</label>
          <input type="number" class="form-control mono prod-unit-price" data-index="${idx}" data-type="purchase" value="${purchase}" min="0" step="0.01">
        </div>
        <div class="form-group mb-0">
          <label class="form-label">Продажа</label>
          <input type="number" class="form-control mono prod-unit-price" data-index="${idx}" data-type="retail" value="${retail}" min="0" step="0.01">
        </div>
      </div>
    `;
  }).join('');

  prodUnitPriceRowsWrap.querySelectorAll('.prod-unit-price').forEach((input) => {
    input.addEventListener('input', () => {
      const idx = parseInt(input.dataset.index || '0', 10);
      const type = input.dataset.type || 'purchase';
      prodUnitPriceState[idx] = prodUnitPriceState[idx] || {};
      prodUnitPriceState[idx][type] = input.value;
      if (idx === 0) {
        renderModalUnitPrices();
      }
    });
  });
}

function syncModalUnitRatios() {
  let cumulative = 1;
  document.querySelectorAll('#prod-unit-rows .prod-unit-row').forEach((row) => {
    const stepInput = row.querySelector('.prod-unit-step');
    const ratioInput = row.querySelector('.prod-unit-ratio');
    const stepValue = parseFloat(stepInput?.value || 1) || 1;
    cumulative *= stepValue > 0 ? stepValue : 1;
    if (ratioInput) ratioInput.value = cumulative.toFixed(3);
  });
  renderModalUnitPrices();
}

function bindModalUnitRow(row) {
  row.querySelector('.prod-unit-remove')?.addEventListener('click', () => {
    row.remove();
    syncModalUnitRatios();
  });
  row.querySelector('.prod-unit-label')?.addEventListener('input', renderModalUnitPrices);
  row.querySelector('.prod-unit-step')?.addEventListener('input', syncModalUnitRatios);
}

function addModalUnitRow(label = '', step = '1') {
  if (!prodUnitRowsWrap) return;
  const row = document.createElement('div');
  row.className = 'prod-unit-row';
  row.style.cssText = 'display:grid;grid-template-columns:1.2fr .9fr auto;gap:10px;align-items:end';
  row.innerHTML = `
    <div class="form-group mb-0">
      <label class="form-label">Следующая единица</label>
      <input type="text" class="form-control prod-unit-label" value="${label}" placeholder="Мешок / Коробка / Штука">
    </div>
    <div class="form-group mb-0">
      <label class="form-label">Сколько предыдущих внутри</label>
      <input type="hidden" class="prod-unit-ratio" value="1">
      <input type="number" class="form-control mono prod-unit-step" value="${step}" min="0.001" step="0.001">
    </div>
    <button type="button" class="btn btn-sm btn-danger prod-unit-remove"><i data-feather="trash-2" style="width:14px;height:14px;vertical-align:middle"></i></button>
  `;
  prodUnitRowsWrap.appendChild(row);
  bindModalUnitRow(row);
  syncModalUnitRatios();
  feather.replace();
}

// ── Row management ────────────────────────────────────────────────
document.getElementById('btn-add-row').addEventListener('click', function () {
  rowIndex++;
  const html = document.getElementById('row-template').innerHTML.replaceAll('__IDX__', rowIndex);
  const tr   = document.createElement('tr');
  tr.innerHTML = html;
  document.getElementById('items-body').appendChild(tr);
  feather.replace();
  initRow(tr);
  renumberRows();
  recalcTotals();
});

document.querySelectorAll('#items-body tr').forEach(initRow);
recalcTotals();

function initRow(tr) {
  const productSel = tr.querySelector('.row-product-select');
  const nameInput  = tr.querySelector('.row-name');
  const unitSel    = tr.querySelector('.row-unit');
  const priceInput = tr.querySelector('.row-price');
  const delBtn     = tr.querySelector('.btn-del-row');
  const newProdBtn = tr.querySelector('.btn-new-product-row');

  if (productSel) {
    productSel.addEventListener('change', function () {
      const p = PROD_MAP[this.value];
      if (p) {
        nameInput.value  = p.name;
        fillUnitOptions(unitSel, p, p.unit);
        tr.dataset.priceOverrides = JSON.stringify({});
        applyRowUnitPrice(tr, p, unitSel.value || p.unit);
        renderReceiptUnitMatrix(tr, p);
      }
      recalcRow(tr);
    });
  }

  unitSel?.addEventListener('change', function () {
    const p = PROD_MAP[productSel?.value];
    if (!p) return;
    applyRowUnitPrice(tr, p, this.value);
    renderReceiptUnitMatrix(tr, p);
    recalcRow(tr);
  });

  priceInput?.addEventListener('input', function () {
    const p = PROD_MAP[productSel?.value];
    if (!p) return;
    rememberRowPrice(tr, p, unitSel?.value, this.value);
    renderReceiptUnitMatrix(tr, p);
  });

  // "+" button in each row → open product modal tied to this row
  if (newProdBtn) {
    newProdBtn.addEventListener('click', () => openProductModal(tr));
  }

  tr.querySelectorAll('.row-qty, .row-price, .row-tax').forEach(el => {
    el.addEventListener('input', () => recalcRow(tr));
  });

  if (delBtn) {
    delBtn.addEventListener('click', function () {
      tr.remove();
      renumberRows();
      recalcTotals();
    });
  }

  recalcRow(tr);

  if (productSel?.value && PROD_MAP[productSel.value]) {
    const product = PROD_MAP[productSel.value];
    fillUnitOptions(unitSel, product, unitSel.value || product.unit);
    if (!(tr.querySelector('.row-unit-prices-json')?.value || '').trim()) {
      rememberRowPrice(tr, product, unitSel.value || product.unit, priceInput?.value || 0);
    }
    renderReceiptUnitMatrix(tr, product);
  }
}

function recalcRow(tr) {
  const qty   = parseFloat(tr.querySelector('.row-qty')?.value)   || 0;
  const price = parseFloat(tr.querySelector('.row-price')?.value) || 0;
  const cell  = tr.querySelector('.row-total');
  if (cell) cell.textContent = (qty * price).toFixed(2);
  recalcTotals();
}

function recalcTotals() {
  let sub = 0, tax = 0;
  document.querySelectorAll('#items-body tr').forEach(tr => {
    const qty   = parseFloat(tr.querySelector('.row-qty')?.value)   || 0;
    const price = parseFloat(tr.querySelector('.row-price')?.value) || 0;
    const rate  = parseFloat(tr.querySelector('.row-tax')?.value)   || 0;
    const line  = qty * price;
    sub += line;
    tax += line * rate / 100;
  });
  document.getElementById('grand-subtotal').textContent = sub.toFixed(2);
  document.getElementById('grand-tax').textContent      = tax.toFixed(2);
  document.getElementById('grand-total').textContent    = (sub + tax).toFixed(2);
}

function renumberRows() {
  document.querySelectorAll('#items-body tr').forEach((tr, i) => {
    const n = tr.querySelector('.row-num');
    if (n) n.textContent = i + 1;
  });
}

// ── Modal helpers ─────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

document.querySelectorAll('.qc-overlay').forEach(overlay => {
});
document.querySelectorAll('[data-close-modal]').forEach(btn => {
  btn.addEventListener('click', () => closeModal(btn.dataset.closeModal));
});

function showError(elId, msg) {
  const el = document.getElementById(elId);
  el.textContent = msg;
  el.classList.add('show');
}
function clearError(elId) {
  const el = document.getElementById(elId);
  el.textContent = '';
  el.classList.remove('show');
}
function setLoading(btn, on) {
  btn.disabled = on;
  btn.style.opacity = on ? '.55' : '1';
}

// ── Quick-create Supplier ─────────────────────────────────────────
document.getElementById('btn-new-supplier').addEventListener('click', function () {
  clearError('supplier-error');
  ['sup-name','sup-phone','sup-inn','sup-contact','sup-address'].forEach(id => {
    document.getElementById(id).value = '';
  });
  openModal('modal-supplier');
  setTimeout(() => document.getElementById('sup-name').focus(), 80);
});

document.getElementById('btn-supplier-save').addEventListener('click', async function () {
  clearError('supplier-error');
  const name = document.getElementById('sup-name').value.trim();
  if (!name) {
    showError('supplier-error', "\u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e: \u041d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435");
    return;
  }
  setLoading(this, true);
  try {
    const fd = new FormData();
    fd.append('action',  'create_supplier');
    fd.append('_token',  CSRF_TOKEN);
    fd.append('name',    name);
    fd.append('phone',   document.getElementById('sup-phone').value.trim());
    fd.append('inn',     document.getElementById('sup-inn').value.trim());
    fd.append('contact', document.getElementById('sup-contact').value.trim());
    fd.append('address', document.getElementById('sup-address').value.trim());

    const json = await postAjax(fd);
    if (!json.success) { showError('supplier-error', json.error); return; }

    // Inject new option and select it
    const sel = document.getElementById('supplier-select');
    sel.add(new Option(json.data.name, json.data.id, true, true));
    sel.value = json.data.id;

    closeModal('modal-supplier');
  } catch (e) {
    showError('supplier-error', e.message || 'Network error');
  } finally {
    setLoading(this, false);
  }
});

// ── Quick-create Product ──────────────────────────────────────────
function openProductModal(tr) {
  _targetRow = tr;
  clearError('product-error');
  ['prod-name-ru','prod-name-en','prod-sku','prod-barcode'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('prod-unit-label').value = '';
  document.getElementById('prod-image').value = '';
  document.getElementById('prod-image-preview').style.display = 'none';
  if (prodUnitRowsWrap) prodUnitRowsWrap.innerHTML = '';
  Object.keys(prodUnitPriceState).forEach(key => delete prodUnitPriceState[key]);
  prodUnitPriceState[0] = { purchase: '0.00', retail: '0.00' };
  syncModalUnitRatios();
  openModal('modal-product');
  setTimeout(() => document.getElementById('prod-name-ru').focus(), 80);
}

document.getElementById('prod-add-unit-row')?.addEventListener('click', () => addModalUnitRow());
prodBaseUnitLabel?.addEventListener('input', renderModalUnitPrices);
prodBaseUnitSelect?.addEventListener('change', renderModalUnitPrices);

document.getElementById('btn-product-save').addEventListener('click', async function () {
  clearError('product-error');
  const nameRu = document.getElementById('prod-name-ru').value.trim();
  const nameEn = document.getElementById('prod-name-en').value.trim();
  if (!nameRu && !nameEn) {
    showError('product-error', "\u041e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e: \u041d\u0430\u0438\u043c\u0435\u043d\u043e\u0432\u0430\u043d\u0438\u0435");
    return;
  }
  setLoading(this, true);
  try {
    const fd = new FormData();
    fd.append('action',      'create_product');
    fd.append('_token',      CSRF_TOKEN);
    fd.append('name_ru',     nameRu);
    fd.append('name_en',     nameEn);
    fd.append('sku',         document.getElementById('prod-sku').value.trim());
    fd.append('barcode',     document.getElementById('prod-barcode').value.trim());
    fd.append('category_id', document.getElementById('prod-category').value);
    fd.append('unit',        document.getElementById('prod-unit').value);
    fd.append('unit_label',  document.getElementById('prod-unit-label').value.trim());
    document.querySelectorAll('#prod-unit-rows .prod-unit-row').forEach((row, idx) => {
      fd.append(`unit_rows[${idx}][unit_label]`, row.querySelector('.prod-unit-label')?.value.trim() || '');
      fd.append(`unit_rows[${idx}][ratio_to_base]`, row.querySelector('.prod-unit-ratio')?.value || '1');
    });
    modalCurrentUnits().forEach((unit, idx) => {
      fd.append(`unit_price_rows[${idx}][purchase]`, prodUnitPriceState[idx]?.purchase || (idx === 0 ? '0' : ''));
      fd.append(`unit_price_rows[${idx}][retail]`, prodUnitPriceState[idx]?.retail || (idx === 0 ? '0' : ''));
    });
    const imgFile = document.getElementById('prod-image').files[0];
    if (imgFile) fd.append('image', imgFile);

    const json = await postAjax(fd);
    if (!json.success) { showError('product-error', json.error); return; }

    const p = json.data;

    // Add to runtime catalogue
    PROD_MAP[p.id] = p;

    // Add option to every existing product dropdown on the page
    document.querySelectorAll('.row-product-select').forEach(sel => {
      sel.add(new Option(p.name + ' [' + p.sku + ']', p.id));
    });

    // Select new product in the row that triggered the modal and fire change
    if (_targetRow) {
      const sel = _targetRow.querySelector('.row-product-select');
      if (sel) {
        sel.value = p.id;
        sel.dispatchEvent(new Event('change'));
      }
    }

    closeModal('modal-product');
  } catch (e) {
    showError('product-error', e.message || 'Network error');
  } finally {
    setLoading(this, false);
  }
});

// ── Image preview ─────────────────────────────────────────────────
document.getElementById('prod-image').addEventListener('change', function () {
  const preview = document.getElementById('prod-image-preview');
  if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = e => {
      preview.src = e.target.result;
      preview.style.display = 'block';
    };
    reader.readAsDataURL(this.files[0]);
  } else {
    preview.style.display = 'none';
  }
});

renderModalUnitPrices();

async function postAjax(formData) {
  const res = await fetch(AJAX_URL, {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest' },
    body: formData,
  });
  const json = await res.json().catch(() => null);
  if (!res.ok) {
    throw new Error(json?.error || ('HTTP ' + res.status));
  }
  return json;
}

// ── Post confirm ──────────────────────────────────────────────────
document.querySelectorAll('[data-confirm]').forEach(el => {
  el.addEventListener('click', e => { if (!confirm(el.dataset.confirm)) e.preventDefault(); });
});
</script>
